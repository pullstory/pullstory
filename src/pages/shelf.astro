---
// My shelf = 공개 진열장. 누구나 프로필 + 연재/공개 노트를 봄.
// CASH Room 입구 + 비공개 노트는 "주인(로그인)"에게만. 로그인은 상단 nav 버튼(Base).
import { marked } from 'marked';
import Base from '../layouts/Base.astro';
import PostList from '../components/PostList.astro';
import { getPage, getPublishedPosts } from '../lib/notion.js';

const md = await getPage('shelf');
const profileHtml = md ? marked.parse(md) : '';
const posts = await getPublishedPosts();
---
<Base title="My shelf · PULLSTORY" description="PULLSTORY 책장 — 연재하고 출간한 이야기를 진열하는 곳.">
  {profileHtml
    ? <section class="profile" set:html={profileHtml} />
    : <section class="profile"><h1>My shelf</h1></section>}

  <!-- CASH Room 입구 — 주인(로그인)에게만 -->
  <section id="owner-only" hidden>
    <hr />
    <section class="app-entry">
      <h2>CASH Room</h2>
      <p class="app-desc">내 이야기를 짓는 작업실 방. 매일의 기록으로 나만의 책을 만들어, 이 책장에 진열합니다.</p>
      <a class="app-open" href="/app/">CASH Room 들어가기 →</a>
    </section>
  </section>

  <hr />

  <!-- 노트 (방문자: 공개만 / 주인: 전체) -->
  <section class="content">
    <h2 id="notes-title">노트</h2>
    <div id="my-notes"><p class="lede">불러오는 중…</p></div>
  </section>

  {posts.length > 0 && (
    <>
      <hr />
      <section class="content">
        <h2>연재</h2>
        <PostList posts={posts} />
      </section>
    </>
  )}

  <!-- Firestore (노트 로드). auth/init은 Base(nav)에서 이미 처리됨 -->
  <script is:inline src="https://www.gstatic.com/firebasejs/10.13.2/firebase-firestore-compat.js"></script>
  <script is:inline>
    (function () {
      var db = firebase.firestore();
      var auth = firebase.auth();
      var $ = function (id) { return document.getElementById(id); };
      function esc(s) {
        return (s || '').replace(/[&<>"]/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
        });
      }
      function collect(snap) { var a = []; snap.forEach(function (d) { var x = d.data(); x.id = d.id; a.push(x); }); return a; }
      function render(items, owner) {
        items.sort(function (a, b) {
          return (((b.createdAt && b.createdAt.seconds) || 9e15) - ((a.createdAt && a.createdAt.seconds) || 9e15));
        });
        if (!items.length) {
          $('my-notes').innerHTML = owner
            ? '<p class="lede">아직 노트가 없어요. CASH Room에서 써보세요.</p>'
            : '<p class="lede">아직 공개된 글이 없어요.</p>';
          return;
        }
        var html = '<ul class="note-list">';
        items.forEach(function (n) {
          var pub = n.visibility === 'public';
          var badge = owner ? '<span class="note-badge ' + (pub ? 'pub' : 'priv') + '">' + (pub ? '공개' : '나만') + '</span>' : '';
          var body = n.body ? '<div class="note-body">' + esc(n.body) + '</div>' : '';
          html += '<li class="note-item"><div class="note-head"><span class="note-title">' +
            esc(n.title || '(제목 없음)') + '</span>' + badge + '</div>' + body + '</li>';
        });
        html += '</ul>';
        $('my-notes').innerHTML = html;
      }
      function loadOwner(uid) {
        db.collection('notes').where('ownerUid', '==', uid).get()
          .then(function (s) { render(collect(s), true); })
          .catch(function (e) { $('my-notes').innerHTML = '<p class="lede">불러오기 실패: ' + esc(e.message) + '</p>'; });
      }
      function loadPublic() {
        db.collection('notes').where('visibility', '==', 'public').get()
          .then(function (s) { render(collect(s), false); })
          .catch(function (e) { $('my-notes').innerHTML = '<p class="lede">불러오기 실패: ' + esc(e.message) + '</p>'; });
      }
      auth.onAuthStateChanged(function (u) {
        if (u) {
          $('owner-only').hidden = false;
          $('notes-title').textContent = '내 노트';
          loadOwner(u.uid);
        } else {
          $('owner-only').hidden = true;
          $('notes-title').textContent = '노트';
          loadPublic();
        }
      });
    })();
  </script>
</Base>
