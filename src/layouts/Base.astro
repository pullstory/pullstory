---
const { title = 'PULLSTORY', description = 'PULLSTORY — 자기 인생을 책처럼 써내려가는 환경.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans KR", sans-serif;
        color: #222;
        line-height: 1.75;
      }
      /* 콘텐츠를 가운데 좁은 칼럼으로 정리 */
      .wrap {
        max-width: 680px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 5rem;
      }
      nav a { color: #222; text-decoration: none; }
      nav a:hover { text-decoration: underline; }
      hr { border: none; border-top: 1px solid #e7e7e7; margin: 1.5rem 0; }
      /* 이미지: 칼럼 폭에 맞추고 가운데 */
      img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 1.75rem auto;
        border-radius: 4px;
      }
      /* 유튜브/임베드: 반응형 16:9 */
      .embed { position: relative; padding-top: 56.25%; margin: 1.75rem 0; }
      .embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; border-radius: 4px; }
      /* 콘텐츠 목록 (제목 + 썸네일) */
      .post-list { list-style: none; padding: 0; margin: 0; }
      .post-list li { border-bottom: 1px solid #f0f0f0; }
      .post-item {
        display: flex;
        align-items: center;
        gap: .9rem;
        padding: .8rem 0;
        color: #222;
        text-decoration: none;
      }
      .post-item:hover .post-title { text-decoration: underline; }
      /* 썸네일: 작은 고정 크기 (전역 img 규칙 덮어씀) */
      .thumb {
        width: 72px;
        height: 72px;
        object-fit: cover;
        border-radius: 6px;
        margin: 0;
        flex-shrink: 0;
        display: block;
      }
      .thumb--empty { background: #f0f0f0; }
      .post-meta { display: flex; flex-direction: column; gap: .15rem; }
      .post-title { font-weight: 500; }
      .post-meta time { color: #999; font-size: .82rem; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <!-- 메뉴 (앞으로 항목 추가 예정) -->
      <nav>
        <a href="/">PULLSTORY</a>
        |
        <a href="/">About</a>
      </nav>

      <hr />

      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
