---
const { title = 'PULLSTORY', description = 'PULLSTORY — 자기 인생을 책처럼 써내려가는 환경.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans KR", sans-serif;
        color: #222;
        line-height: 1.75;
      }
      /* 콘텐츠를 가운데 좁은 칼럼으로 정리 */
      .wrap {
        max-width: 680px;
        margin: 0 auto;
        padding: 1.5rem 1.25rem 5rem;
      }
      nav { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .6rem; }
      .nav-left { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
      nav a { color: #222; text-decoration: none; }
      nav a:hover { text-decoration: underline; }
      .brand { font-weight: 700; letter-spacing: .02em; }
      .nav-login { background: none; border: 1px solid #ccc; border-radius: 6px; padding: .35rem .85rem; cursor: pointer; color: #222; font-size: .88rem; }
      .nav-login:hover { background: #222; color: #fff; border-color: #222; }
      hr { border: none; border-top: 1px solid #e7e7e7; margin: 1.5rem 0; }
      /* 이미지: 칼럼 폭에 맞추고 가운데 */
      img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 1.75rem auto;
        border-radius: 4px;
      }
      /* 유튜브/임베드: 반응형 16:9 */
      .embed { position: relative; padding-top: 56.25%; margin: 1.75rem 0; }
      .embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; border-radius: 4px; }
      /* 콘텐츠 목록 (제목 + 썸네일) */
      .post-list { list-style: none; padding: 0; margin: 0; }
      .post-list li { border-bottom: 1px solid #f0f0f0; }
      .post-item {
        display: flex;
        align-items: center;
        gap: .9rem;
        padding: .8rem 0;
        color: #222;
        text-decoration: none;
      }
      .post-item:hover .post-title { text-decoration: underline; }
      /* 썸네일: 작은 고정 크기 (전역 img 규칙 덮어씀) */
      .thumb {
        width: 72px;
        height: 72px;
        object-fit: cover;
        border-radius: 6px;
        margin: 0;
        flex-shrink: 0;
        display: block;
      }
      .thumb--empty { background: #f0f0f0; }
      .post-meta { display: flex; flex-direction: column; gap: .15rem; }
      .post-title { font-weight: 500; }
      .post-meta time { color: #999; font-size: .82rem; }
      .lede { color: #666; margin: .2rem 0 1.5rem; }
      .profile { margin-bottom: .5rem; }
      .app-entry { margin: .5rem 0; }
      .app-desc { color: #666; }
      .app-open {
        display: inline-block;
        margin-top: .3rem;
        padding: .6rem 1.15rem;
        border: 1px solid #222;
        border-radius: 8px;
        color: #222;
        text-decoration: none;
        font-weight: 500;
      }
      .app-open:hover { background: #222; color: #fff; }
      .text-btn { background: none; border: none; color: #999; text-decoration: underline; cursor: pointer; font-size: .85rem; padding: 0; }
      .note-list { list-style: none; padding: 0; margin: 0; }
      .note-item { border-bottom: 1px solid #f0f0f0; padding: .8rem 0; }
      .note-head { display: flex; align-items: center; gap: .5rem; }
      .note-title { font-weight: 600; }
      .note-badge { font-size: .7rem; font-weight: 700; padding: 1px 8px; border-radius: 20px; }
      .note-badge.pub { background: rgba(90,140,74,.15); color: #4a7a3a; }
      .note-badge.priv { background: rgba(107,79,48,.12); color: #8a6630; }
      .note-body { color: #555; font-size: .9rem; margin-top: .3rem; white-space: pre-wrap; max-height: 3em; overflow: hidden; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <!-- 메뉴 (앞으로 항목 추가 예정) -->
      <nav>
        <div class="nav-left">
          <a href="/" class="brand">PULLSTORY</a>
          <a href="/about/">About</a>
          <a href="/shelf/">My shelf</a>
          <a href="/item/">Item</a>
        </div>
        <button id="nav-login" class="nav-login" type="button">로그인</button>
      </nav>

      <!-- Firebase 전역 로그인 (모든 페이지 nav) -->
      <script is:inline src="https://www.gstatic.com/firebasejs/10.13.2/firebase-app-compat.js"></script>
      <script is:inline src="https://www.gstatic.com/firebasejs/10.13.2/firebase-auth-compat.js"></script>
      <script is:inline>
        if (!firebase.apps.length) {
          firebase.initializeApp({
            apiKey: "AIzaSyDd0g3kHwxQJ74z8UJc0sVCoGRNRvSY-b4",
            authDomain: "pullstory.firebaseapp.com",
            projectId: "pullstory",
            storageBucket: "pullstory.firebasestorage.app",
            messagingSenderId: "20024128938",
            appId: "1:20024128938:web:67ca8a5a5ed6155cd427d3"
          });
        }
        (function () {
          var a = firebase.auth();
          var p = new firebase.auth.GoogleAuthProvider();
          var b = document.getElementById('nav-login');
          b.addEventListener('click', function () {
            if (a.currentUser) a.signOut();
            else a.signInWithPopup(p).catch(function (e) { alert('로그인 실패: ' + e.message); });
          });
          a.onAuthStateChanged(function (u) { b.textContent = u ? '로그아웃' : '로그인'; });
        })();
      </script>

      <hr />

      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
